# =============================================================================
# Lora Magazine Academic - Supabase Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp env.supabase.example .env

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase URL
SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase anon key (public)
SUPABASE_KEY="your-supabase-anon-key"

# Supabase service role key (private, server-only)
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# =============================================================================
# AUTH0 CONFIGURATION (Optional)
# =============================================================================
# Get these values from your Auth0 application settings

# Auth0 application secret (generate a random string)
AUTH0_SECRET="your-auth0-secret-here"

# Auth0 application client ID
AUTH0_CLIENT_ID="your-auth0-client-id"

# Auth0 application client secret
AUTH0_CLIENT_SECRET="your-auth0-client-secret"

# Auth0 domain (e.g., dev-abc123.us.auth0.com)
AUTH0_DOMAIN="your-auth0-domain"

# Base URL for your application
AUTH0_BASE_URL="https://www.digitalevolutionjournal.com/"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for local development server
PORT=3000

# Node environment
NODE_ENV="development"

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Maximum file size for uploads (in bytes)
MAX_FILE_SIZE=26214400

# Allowed file types for paper submissions
ALLOWED_PAPER_TYPES=".doc,.docx,.pdf"

# Allowed file types for CV uploads
ALLOWED_CV_TYPES=".pdf"

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS
CORS_ORIGIN="http://localhost:3000,https://your-domain.com"

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL="info"