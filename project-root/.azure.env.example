# =============================================================================
# Digital Evolution Journal - Azure Environment Example (DEPRECATED)
# =============================================================================
# NOTE: This configuration is deprecated as the application has migrated to Supabase.
# This file is kept for reference purposes only.

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=production
PORT=8080

# =============================================================================
# DATABASE CONFIGURATION - AZURE COSMOS DB
# =============================================================================
# Replace with your actual Cosmos DB connection string
DATABASE_URL=mongodb://<cosmosdb-account-name>:<primary-key>@<cosmosdb-account-name>.mongo.cosmos.azure.com:10255/<database-name>?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@<cosmosdb-account-name>@

# =============================================================================
# AUTH0 CONFIGURATION
# =============================================================================
AUTH0_SECRET=your-auth0-secret
AUTH0_BASE_URL=https://your-azure-app-name.azurewebsites.net
AUTH0_ISSUER_BASE_URL=https://your-auth0-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_DOMAIN=your-auth0-domain

# =============================================================================
# AZURE STORAGE CONFIGURATION
# =============================================================================
STORAGE_ACCOUNT_NAME=yourazurestorage
STORAGE_ACCOUNT_KEY=your-storage-account-key
STORAGE_CONTAINER_NAME=papers

# =============================================================================
# APPLICATION INSIGHTS (OPTIONAL)
# =============================================================================
APPLICATIONINSIGHTS_CONNECTION_STRING=your-application-insights-connection-string

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
SESSION_OPTIONS_SECURE=true

# =============================================================================
# LOGGING
# =============================================================================
VERBOSE_LOGGING=false